# ============================================================
# Rutina Backend - 환경 변수 샘플
# 이 파일을 .env로 복사한 뒤 값을 채워 사용하세요.
#   cp .env.sample .env
# ============================================================
SPRING_PROFILES_ACTIVE=local

# ── [필수] Database (Supabase PostgreSQL) ───────────────────
# Flyway/DDL은 Direct Connection(5432), 런타임은 Pooler(6543) 사용
DB_URL=jdbc:postgresql://your-project.supabase.co:6543/postgres
DB_USERNAME=
DB_PASSWORD=

# ── [필수] JWT ──────────────────────────────────────────────
JWT_SECRET=

# ── [필수] AI 추천 (OpenAI) ─────────────────────────────────
OPENAI_API_KEY=

# ── [필수] 소셜 로그인 OAuth2 ───────────────────────────────
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 로그인 성공 후 앱으로 돌아갈 콜백 URL
OAUTH2_REDIRECT_URL=

# Apple 로그인 (iOS) - Apple 로그인 검증 시 필요
APPLE_BUNDLE_ID=com.rutina.app

# ── [선택] Redis ────────────────────────────────────────────
# local 프로파일에서는 InMemory 구현으로 대체되므로 비워둬도 됩니다.
# (RedisAutoConfiguration이 application-local.yaml에서 제외됨)
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=

# ── [선택] 이메일 (AWS SES SMTP) ────────────────────────────
# 이메일 인증/비밀번호 재설정 발송 시 필요합니다.
SES_SMTP_USERNAME=
SES_SMTP_PASSWORD=
